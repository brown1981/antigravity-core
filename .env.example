# .env.example - VPSにデプロイする際にこのファイルをコピーして .env を作成してください
# cp .env.example .env
# その後、各項目に実際のAPIキーを入力してください

OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Webサーバーのポート番号（Renderなどのクラウドでは自動設定されます）
PORT=8080

# セキュリティ用のシークレットキー（任意の長い文字列を設定してください）
SECRET_KEY=change_this_to_a_long_random_string
