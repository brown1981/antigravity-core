# AI Corp — 設定ファイル
# =========================================================
# このファイルを .env としてコピーし、キーを入力してください
# cp .env.example .env
# =========================================================

# Groq API Key（CMO, CTO, CFO, CDO, CLO, CSO 用・超高速推論）
# 取得: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key（CEO / 高度なモデル切り替え用）
# 取得: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API Key（CLO特化・大容量ドキュメントのContext Caching用）
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =========================================================
# モデル個別上書き設定（変更したい役職のみ記入）
# デフォルトは agents.py 内の設定が使われます
# =========================================================
# ROLE_CEO_MODEL=groq/llama-3.1-70b-versatile
# ROLE_CMO_MODEL=groq/llama-3.1-8b-instant
# ROLE_CTO_MODEL=groq/gemma2-9b-it
# ROLE_CFO_MODEL=groq/llama-3.1-70b-versatile
# ROLE_CDO_MODEL=groq/llama-3.1-8b-instant
# ROLE_CLO_MODEL=groq/llama-3.1-70b-versatile
# ROLE_CSO_MODEL=groq/llama-3.1-70b-versatile

# =========================================================
# 開発・デバッグ
# =========================================================
# true にするとAPIを叩かずにシミュレーションで動作します
ANY_MODEL_MOCK=false
